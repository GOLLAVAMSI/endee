# ============================================
# AI Cyber Threat Intelligence Assistant
# Environment Variables Configuration
# ============================================

# Groq API Key (FREE — get yours at https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# LLM Configuration (Groq with Llama 3.3 70B — free & fast)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Endee Vector Database Configuration (optional — falls back to local if unavailable)
ENDEE_HOST=localhost
ENDEE_PORT=8080

# Embedding Model (default: all-MiniLM-L6-v2, runs locally)
EMBEDDING_MODEL=all-MiniLM-L6-v2
